# ── Database (PostgreSQL terpisah dari Odoo) ──────────────────────────────────
DATABASE_URL="postgresql://mito_user:securepass123@localhost:5433/mito_undian"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="ganti-dengan-string-acak-yang-panjang-minimal-32-karakter"
JWT_EXPIRES_IN="8h"

# ── Odoo 18 XML-RPC ───────────────────────────────────────────────────────────
ODOO_URL="http://your-odoo-host:8069"
ODOO_DB="your_odoo_database_name"
ODOO_USERNAME="api_user@company.com"
ODOO_PASSWORD="odoo_api_user_password"

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY="AIzaSy..."
GEMINI_MODEL="gemini-1.5-flash"

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_TYPE="cloudinary"

CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your-api-secret"

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME="mito-undian-struk"
AWS_REGION="ap-southeast-1"

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

REDIS_URL="redis://localhost:6380"
